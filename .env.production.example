# FlatScout Production Environment Variables
# Copy this to .env.production and fill in real values

# Firecrawl — https://firecrawl.dev
FIRECRAWL_API_KEY=fc-xxx

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_AGENT_ID=xxx
ELEVENLABS_API_KEY=xi_xxx

# PostgreSQL (must match docker-compose.prod.yml)
DATABASE_URL=postgresql://postgres:postgres@db:5432/flatscout

# Server
PORT=3000
NODE_ENV=production

# Optional app login for the browser UI
APP_LOGIN_USERNAME=
APP_LOGIN_PASSWORD=
APP_SESSION_SECRET=

# Optional shared secret for ElevenLabs server tools
TOOL_API_SECRET=
